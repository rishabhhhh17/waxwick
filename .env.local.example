# Razorpay (test or live)
RAZORPAY_KEY_ID=rzp_test_xxxx
RAZORPAY_KEY_SECRET=xxxx
RAZORPAY_WEBHOOK_SECRET=xxxx
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxx

# Meta Pixel + Conversions API
NEXT_PUBLIC_META_PIXEL_ID=123456789012345
META_ACCESS_TOKEN=EAAxxxxx
# Optional: leave empty in prod, set while validating in Events Manager
META_TEST_EVENT_CODE=

# Admin (single password + 32+ char random secret for the JWT cookie)
ADMIN_PASSWORD=change-me
ADMIN_SESSION_SECRET=replace-with-openssl-rand-hex-32

# Public site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://waxwick.in
